            Tween(tab.Button, 0.2, { BackgroundColor3 = Color3.fromRGB(20, 20, 26) })
            Tween(tabLabel, 0.2, { TextColor3 = Color3.fromRGB(140, 140, 150) })
        end
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Auto-select first tab
    if #self.Tabs == 1 then
        self:SwitchTab(tab)
    end
    
    return tab
end

function Window:SwitchTab(tab)
    -- Deactivate all
    for _, t in pairs(self.Tabs) do
        t.ContentFrame.Visible = false
        t.ActiveIndicator.Visible = false
        Tween(t.Button, 0.2, { BackgroundColor3 = Color3.fromRGB(20, 20, 26) })
        Tween(t.Label, 0.2, { TextColor3 = Color3.fromRGB(140, 140, 150) })
    end
    
    -- Activate selected
    self.ActiveTab = tab
    tab.ContentFrame.Visible = true
    tab.ActiveIndicator.Visible = true
    Tween(tab.Button, 0.2, { BackgroundColor3 = Color3.fromRGB(25, 25, 32) })
    Tween(tab.Label, 0.2, { TextColor3 = Color3.fromRGB(255, 255, 255) })
end

