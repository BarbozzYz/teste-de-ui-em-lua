        Text = tostring(element.Value) .. "%",
        TextColor3 = self.Window.AccentColor,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    local trackBg = Create("Frame", {
        Parent = frame,
        BackgroundColor3 = Color3.fromRGB(30, 30, 38),
        Position = UDim2.new(0, 16, 0, 32),
        Size = UDim2.new(1, -32, 0, 6),
        BorderSizePixel = 0,
    })
    Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = trackBg })
    
    local pct = (element.Value - element.Min) / (element.Max - element.Min)
    local fill = Create("Frame", {
        Parent = trackBg,
        BackgroundColor3 = self.Window.AccentColor,
        Size = UDim2.new(pct, 0, 1, 0),
        BorderSizePixel = 0,
    })
    Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })
    
    -- Slider handle
    local handle = Create("Frame", {
        Parent = trackBg,
        BackgroundColor3 = self.Window.AccentColor,
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(pct, -8, 0.5, -8),
        BorderSizePixel = 0,
    })
    Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = handle })
    
    -- Handle glow
    local handleGlow = GlowEffect(handle, self.Window.AccentColor)
    handleGlow.Size = UDim2.new(1, 8, 1, 8)
    handleGlow.Position = UDim2.new(0.5, -4, 0.5, -4)
    handleGlow.ImageTransparency = 0.6
    
    -- Drag logic
    local dragging = false
    local sliderBtn = Create("TextButton", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 24),
        Size = UDim2.new(1, -32, 0, 22),
        Text = "",
    })
    
    sliderBtn.MouseButton1Down:Connect(function()
        dragging = true
        RippleEffect(handle)
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    local sliderConnection
    sliderConnection = RunService.RenderStepped:Connect(function()
        if dragging then
            local absPos = trackBg.AbsolutePosition.X
            local absSize = trackBg.AbsoluteSize.X
            local mouseX = Mouse.X
            local newPct = math.clamp((mouseX - absPos) / absSize, 0, 1)
            local newVal = math.floor(element.Min + newPct * (element.Max - element.Min))
            element.Value = newVal
            valueLabel.Text = tostring(newVal) .. "%"
            fill.Size = UDim2.new(newPct, 0, 1, 0)
            handle.Position = UDim2.new(newPct, -8, 0.5, -8)
            if config.Callback then
                config.Callback(newVal)
            end
        end
    end)
    
    frame.MouseEnter:Connect(function()
        Tween(frame, 0.15, { BackgroundColor3 = Color3.fromRGB(26, 26, 32) })
    end)
    frame.MouseLeave:Connect(function()
        Tween(frame, 0.15, { BackgroundColor3 = Color3.fromRGB(22, 22, 28) })
    end)
    
    table.insert(self.Elements, element)
    return element
end

