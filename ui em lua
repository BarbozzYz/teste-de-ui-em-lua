            element.Value = textbox.Text
            if config.Callback then
                config.Callback(textbox.Text)
            end
        end
    end)
    
    table.insert(self.Elements, element)
    return element
end

-- ═══ Separator ═══
function Tab:CreateSeparator()
    local sep = Create("Frame", {
        Parent = self.ContentFrame,
        BackgroundColor3 = Color3.fromRGB(35, 35, 42),
        Size = UDim2.new(1, 0, 0, 1),
        BorderSizePixel = 0,
        LayoutOrder = #self.Elements + 1,
    })
    table.insert(self.Elements, sep)
end

-- ═══ Label ═══
function Tab:CreateLabel(config)
    config = config or {}
    local lbl = Create("TextLabel", {
        Parent = self.ContentFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 24),
        Text = config.Title or "Label",
        TextColor3 = Color3.fromRGB(140, 140, 150),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = #self.Elements + 1,
    })
    Create("UIPadding", { PaddingLeft = UDim.new(0, 8), Parent = lbl })
    table.insert(self.Elements, lbl)
end

-- ═══ Config System ═══
function BanMeLib:SaveConfig(name)
    local data = {}
    for _, tab in pairs(self.Tabs or {}) do
        for i, elem in pairs(tab.Elements) do
            if elem.Value ~= nil then
                local val = elem.Value
                if typeof(val) == "Color3" then
                    val = {R = val.R, G = val.G, B = val.B}
                elseif typeof(val) == "EnumItem" then
                    val = val.Name
                end
                data[tab.Name .. "_" .. i] = val
            end
        end
    end
    
    local json = HttpService:JSONEncode(data)
    if writefile then
        writefile("BanMe_" .. name .. ".json", json)
    end
end

function BanMeLib:LoadConfig(name)
    if readfile and isfile then
        local path = "BanMe_" .. name .. ".json"
        if isfile(path) then
            local json = readfile(path)
            local data = HttpService:JSONDecode(json)
            for _, tab in pairs(self.Tabs or {}) do
                for i, elem in pairs(tab.Elements) do
                    local key = tab.Name .. "_" .. i
                    if data[key] ~= nil and elem.Set then
                        elem:Set(data[key])
                    end
                end
            end
        end
    end
end

function BanMeLib:SetToggleKey(key)
    self.ToggleKey = key
end

