-- ═══ Minimize / Toggle ═══
function Window:Minimize()
    self.Visible = false
    Tween(self.MainFrame, 0.3, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    }, Enum.EasingStyle.Quad)
    if self.Blur then
        Tween(self.Blur, 0.3, { Size = 0 }, Enum.EasingStyle.Quad)
    end
    self:ShowNotification()
end

function Window:ShowNotification()
    -- Clear old notifications
    for _, child in pairs(self.NotificationGui:GetChildren()) do
        child:Destroy()
    end
    
    local notif = Create("Frame", {
        Parent = self.NotificationGui,
        BackgroundColor3 = Color3.fromRGB(15, 15, 20),
        Position = UDim2.new(1, 10, 1, -60),
        Size = UDim2.new(0, 280, 0, 48),
        AnchorPoint = Vector2.new(1, 1),
        BorderSizePixel = 0,
    })
    Create("UICorner", { CornerRadius = UDim.new(0, 12), Parent = notif })
    Create("UIStroke", { 
        Parent = notif, 
        Color = Color3.fromRGB(40, 40, 48), 
        Thickness = 1 
    })
    
    -- Glow effect
    GlowEffect(notif, self.AccentColor)
    
    -- Icon
    local eyeIcon = Create("TextLabel", {
        Parent = notif,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0, 28, 1, 0),
        Text = "👁️",
        TextSize = 20,
        Font = Enum.Font.Gotham,
        TextColor3 = self.AccentColor,
    })
    
    local notifText = Create("TextLabel", {
        Parent = notif,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 48, 0, 0),
        Size = UDim2.new(1, -60, 1, 0),
        Text = "UI Hidden — Press [End] to show",
        TextColor3 = Color3.fromRGB(180, 180, 190),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    -- Slide in animation
    Tween(notif, 0.5, { Position = UDim2.new(1, -20, 1, -60) }, Enum.EasingStyle.Back)
    
    -- Auto dismiss
    task.delay(4, function()
        if notif and notif.Parent then
            Tween(notif, 0.3, { Position = UDim2.new(1, 10, 1, -60) })
            task.delay(0.3, function()
                if notif and notif.Parent then
                    notif:Destroy()
                end
            end)
        end
    end)
end

function Window:Show()
    self.Visible = true
    self.MainFrame.Size = UDim2.new(0, 0, 0, 0)
    self.MainFrame.BackgroundTransparency = 1
    Tween(self.MainFrame, 0.5, {
        Size = UDim2.new(0, self.Size[1], 0, self.Size[2]),
        BackgroundTransparency = 0
    }, Enum.EasingStyle.Back)
    if self.Blur then
        Tween(self.Blur, 0.4, { Size = 12 }, Enum.EasingStyle.Quad)
    end
end

function Window:Toggle()
    if self.Visible then
        self:Minimize()
    else
        self:Show()
    end
end

function Window:Destroy()
    Tween(self.MainFrame, 0.3, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    })
    if self.Blur then 
        Tween(self.Blur, 0.3, { Size = 0 })
        task.delay(0.3, function() 
            if self.Blur then
                self.Blur:Destroy() 
            end
        end)
    end
    task.delay(0.3, function()
        if self.ScreenGui then
            self.ScreenGui:Destroy()
        end
        if self.NotificationGui then
            self.NotificationGui:Destroy()
        end
    end)
end

