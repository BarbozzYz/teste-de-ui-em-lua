function Window:Minimize()
    self.Visible = false
    Tween(self.MainFrame, 0.3, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    })
    if self.Blur then
        Tween(self.Blur, 0.3, { Size = 0 })
    end
    self:ShowNotification()
end
