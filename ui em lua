    })
    
    -- Slide in animation
    Tween(notif, 0.4, { Position = UDim2.new(1, -16, 1, -60) })
    
    -- Auto dismiss after 4 seconds
    task.delay(4, function()
        if notif and notif.Parent then
            Tween(notif, 0.3, { Position = UDim2.new(1, 10, 1, -60) })
            task.delay(0.3, function()
                if notif and notif.Parent then
                    notif:Destroy()
                end
            end)
        end
    
    -- Animate out with rotation + scale
    Tween(self.MainFrame, 0.4, {
        Size = UDim2.new(0, self.Size[1] * 0.3, 0, 0),
        BackgroundTransparency = 1,
        Rotation = 3,
    }, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    
    -- Show minimize notification
    task.delay(0.2, function()
        NotificationSystem.Push(self.NotifSystem, {
            Title = "UI Minimizada",
            Message = "Pressione [End] para restaurar",
            Icon = "👁",
            Duration = 4,
        })
    end)
end
function Window:Show()
    self.Visible = true
    
    -- Reset and animate in
    self.MainFrame.Size = UDim2.new(0, 0, 0, 0)
    self.MainFrame.BackgroundTransparency = 1
    Tween(self.MainFrame, 0.4, {
    self.MainFrame.Rotation = -2
    
    Tween(self.MainFrame, 0.5, {
        Size = UDim2.new(0, self.Size[1], 0, self.Size[2]),
        BackgroundTransparency = 0
    })
    if self.Blur then
        Tween(self.Blur, 0.3, { Size = 10 })
    end
        BackgroundTransparency = 0,
        Rotation = 0,
    }, Enum.EasingStyle.Back)
    
    -- Flash on show
    local flash = Create("Frame", {
        Parent = self.MainFrame,
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 0.8,
        Size = UDim2.new(1, 0, 1, 0),
        BorderSizePixel = 0,
        ZIndex = 100,
    })
    Tween(flash, 0.6, { BackgroundTransparency = 1 })
    task.delay(0.6, function() flash:Destroy() end)
    
    -- Restore notification
    NotificationSystem.Push(self.NotifSystem, {
        Title = "UI Restaurada",
        Message = "Ban.me está ativa novamente",
        Icon = "✓",
        Duration = 2,
        Color = Color3.fromRGB(80, 220, 120),
    })
