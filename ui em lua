function Window:SwitchTab(tab)
    -- Deactivate all
    for _, t in pairs(self.Tabs) do
        t.ContentFrame.Visible = false
        Tween(t.Button, 0.2, { BackgroundTransparency = 1 })
        Tween(t.Label, 0.2, { TextColor3 = Color3.fromRGB(120, 120, 130) })
        Tween(t.Button, 0.25, { BackgroundTransparency = 1 })
        Tween(t.Label, 0.25, { TextColor3 = Theme.TextMuted })
    end
    
    -- Activate selected
    self.ActiveTab = tab
    tab.ContentFrame.Visible = true
    Tween(tab.Button, 0.2, { BackgroundTransparency = 0.85 })
    Tween(tab.Label, 0.2, { TextColor3 = Color3.fromRGB(255, 255, 255) })
    
    -- Animate active tab
    Tween(tab.Button, 0.25, { BackgroundTransparency = 0.88 })
    Tween(tab.Label, 0.25, { TextColor3 = Theme.TextPrimary })
    
    -- Move indicator to tab position
    local buttonPos = tab.Button.AbsolutePosition
    local containerPos = self.TabContainer.AbsolutePosition
    local relY = buttonPos.Y - containerPos.Y + 8
    Tween(self.TabIndicator, 0.3, {
        Position = UDim2.new(0, 0, 0, 62 + relY),
    }, Enum.EasingStyle.Back)
    
    -- Content appear animation (stagger elements)
    for i, child in ipairs(tab.ContentFrame:GetChildren()) do
        if child:IsA("Frame") then
            child.BackgroundTransparency = 1
            task.delay(i * 0.03, function()
                if child and child.Parent then
                    Tween(child, 0.3, { BackgroundTransparency = 0 })
                end
            end)
        end
    end
end
